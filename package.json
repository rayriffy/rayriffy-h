{
  "name": "riffyh",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "commons/",
    "client/",
    "example/",
    "server/",
    "adapter/*"
  ],
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.11",
    "@types/node": "25.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "typescript": "6.0.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint",
    "*": "bun run fmt"
  }
}
