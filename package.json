{
  "name": "riffyh",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "commons/",
    "database/",
    "client/",
    "example/",
    "execute/",
    "server/",
    "adapter/*"
  ],
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.14",
    "@types/node": "26.0.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "turbo": "2.10.0",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint",
    "!(*.lock)": "bun run fmt"
  },
  "packageManager": "bun@1.3.11"
}
